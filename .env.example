# --- Vercel / Next.js (client + middleware) ---
NEXT_PUBLIC_CONVEX_URL=            # from `bunx convex dev` (dev) / convex dashboard (prod)
NEXT_PUBLIC_CONVEX_SITE_URL=       # optional: the *.convex.site HTTP-actions origin (MCP endpoint).
                                    # Connections page derives it from NEXT_PUBLIC_CONVEX_URL
                                    # (.convex.cloud -> .convex.site) if unset.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY= # Clerk dashboard -> API keys
CLERK_SECRET_KEY=                  # Clerk dashboard -> API keys

# --- Convex deployment env vars (set via `bunx convex env set` or dashboard, NOT here) ---
# CLERK_JWT_ISSUER_DOMAIN=         # Clerk dashboard -> JWT templates -> "convex" -> issuer
# ANTHROPIC_API_KEY=               # Phase 3+
# VOYAGE_API_KEY=                  # Phase 3+
# AI_DAILY_TOKEN_BUDGET=50000      # dev default per 05-ai-pipeline
# OWNER_CLERK_ID=                  # Phase 3+ (ops panel)

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/capture
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/capture
